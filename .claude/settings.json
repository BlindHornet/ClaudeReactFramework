{
  "permissions": {
    "allow": [
      "Bash(*)",
      "Read(*)",
      "Edit(*)",

      "Glob(*)",
      "Grep(*)",
      "Search(*)",

      "Write(./src/**)",
      "Write(./public/**)",
      "Write(./package.json)",
      "Write(./vite.config.*)",
      "Write(./next.config.*)",
      "Write(./astro.config.*)"
    ],
    "deny": [
      "Read(./.env)",
      "Read(./.env.*)",
      "Read(./secrets/**)",
      "Read(./.aws/**)",
      "Read(./.git/**)",
      "Read(**/*.pem)",
      "Read(**/*.key)",

      "Write(./.env*)",
      "Write(./.git/**)",

      "Bash(rm -rf*)",
      "Bash(*DROP TABLE*)",
      "Bash(*TRUNCATE*)",

      "Bash(git push origin main*)",
      "Bash(git push --force *)",
      "Bash(git push -f *)",
      "Bash(git reset --hard *)"
    ],
    "defaultMode": "bypassPermissions"
    /*
      |  Mode	                |  Behavior
      |-----------------------|---------------------------------------------
      |  "default"	          |  Prompts for everything not in the allow list
      |  "acceptEdits"	      |  Auto-approves edits to existing files, still prompts for new file writes
      |  "bypassPermissions"	|  Auto-approves everything — no prompts at all
    */
  },
  "hooks": {
    "PreToolUse": [
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "command": "powershell -NoProfile -Command \"$input = $env:CLAUDE_TOOL_INPUT; if ($input -match '(rm -rf|Remove-Item.*-Recurse|del /s /q|DROP TABLE|TRUNCATE|--force|--hard|format|shutdown)') { exit 2 } else { exit 0 }\""
          }
        ]
      }
    ],
    "Stop": [
      {
        "matcher": ".*",
        "hooks": [
          {
            "type": "command",
            "command": "powershell -NoProfile -WindowStyle Hidden -Command \"for($i=0;$i -lt 3;$i++){ [Console]::Beep(900,150); Start-Sleep -m 80; [Console]::Beep(1200,250); Start-Sleep -m 80 }\""
          }
        ]
      }
    ]
  },
  "env": {
    "CLAUDE_CODE_ENABLE_TELEMETRY": "0"
  }
}
