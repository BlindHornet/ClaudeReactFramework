{
  "permissions": {
    "allow": ["Bash(*)", "Read(*)", "Write(*)", "Edit(*)"],
    "deny": [
      "Read(./.env)",
      "Read(./.env.*)",
      "Read(./secrets/**)",
      "Read(./.aws/**)",
      "Read(**/*.pem)",
      "Read(**/*.key)",
      "Bash(rm -rf*)",
      "Bash(git push origin main*)",
      "Bash(git push --force *)",
      "Bash(git push -f *)",
      "Bash(git reset --hard *)"
    ],
    "defaultMode": "acceptEdits"
  },
  "hooks": {
    "PreToolUse": [
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "command": "powershell -NoProfile -Command \"$input = $env:CLAUDE_TOOL_INPUT; if ($input -match '(rm -rf|DROP TABLE|TRUNCATE|--force|--hard)') { exit 2 } else { exit 0 }\""
          }
        ]
      }
    ],
    "Stop": [
      {
        "matcher": ".*",
        "hooks": [
          {
            "type": "command",
            "command": "powershell -NoProfile -WindowStyle Hidden -Command \"for($i=0;$i -lt 3;$i++){ [Console]::Beep(900,150); Start-Sleep -m 80; [Console]::Beep(1200,250); Start-Sleep -m 80 }\""
          }
        ]
      }
    ]
  },
  "env": {
    "CLAUDE_CODE_ENABLE_TELEMETRY": "0"
  }
}
